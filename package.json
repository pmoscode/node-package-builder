{
  "name": "@pmoscode/node-package-builder",
  "version": "1.2.1",
  "description": "A node package helper which assists you in organizing your package.json for multiple environment",
  "bin": {
    "npb": "bin/npb.js"
  },
  "keywords": [
    "npm",
    "package.json",
    "staging",
    "stage",
    "merge",
    "management",
    "manage",
    "versions"
  ],
  "main": "bin/npb.js",
  "types": "bin/npb.d.ts",
  "repository": "https://github.com/pmoscode/node-package-builder.git",
  "author": "Peter Motzko <info@pmoscode.de>",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "bin/",
    "lib/",
    "LICENSE",
    "Readme.md"
  ],
  "scripts": {
    "build": "yarn tsc && ./prepare_npm_publish.sh",
    "watch": "yarn tsc --watch",
    "lint": "eslint '**/*.{ts,tsx}' --quiet --fix",
    "test": "jest",
    "prepublishOnly": "yarn build",
    "docs": "typedoc",
    "docs:serve": "typedoc && npx -y serve public -l 4000",
    "bump:minor": "yarn version --minor",
    "bump:patch": "yarn version --patch"
  },
  "dependencies": {
    "argparse": "^3.0.0",
    "deepmerge": "^4.3.1",
    "tslog": "^4.11.0"
  },
  "devDependencies": {
    "@types/argparse": "^2.0.17",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.1",
    "@typescript-eslint/eslint-plugin": "^8.65.0",
    "@typescript-eslint/parser": "^8.65.0",
    "@typescript/native": "npm:typescript@^7.0.2",
    "@typhonjs-typedoc/typedoc-theme-dmt": "^0.4.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "jest": "^30.4.2",
    "jest-junit": "^17.0.0",
    "prettier": "^3.9.6",
    "ts-jest": "^29.4.12",
    "ts-node": "^10.9.2",
    "typedoc": "^0.28.20",
    "typescript": "npm:@typescript/typescript6@^6.0.2"
  }
}
